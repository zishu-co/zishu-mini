
<!--pages/login/login.wxml-->
<view class="container">
  <view class="header">
    <image class="logo" src="/img/v2.jpg" mode="aspectFill"></image>
    <!-- <view class="title">欢迎回来</view>
    <view class="subtitle">授权登录后体验更多精彩功能</view> -->
  </view>

  <view class="auth-section">
    <!-- 头像授权 -->
    <view class="auth-item">
      <view class="auth-title">头像授权</view>
      <view class="auth-content" wx:if="{{avatarUrl}}">
        <view class="user-info">
            <image class="avatar" src="{{avatarUrl}}"></image>
        </view>
        <view class="auth-status success">已完成授权</view>
      </view>
      <view class="auth-content" wx:else>
        <view class="auth-desc">用于身份识别</view>
        <button class="pop_avatar" wx:if="{{!avatarUrl}}" open-type="chooseAvatar" bindchooseavatar="getAvatar">获取头像</button>
        <view class="auth-status">待授权</view>
      </view>
    </view>

    <!-- 昵称授权 -->
    <view class="auth-item">
      <view class="auth-title">昵称授权</view>
      <view class="auth-content" wx:if="{{nickName}}">
        <view class="user-info">
          <view class="nickname">{{nickName}}</view>
        </view>
        <view class="auth-status success">已完成授权</view>
      </view>
      <view class="auth-content" wx:else>
        <view class="auth-desc">用于身份识别</view>
        <input wx:if="{{!nickName}}" type="nickname" class="ipu" placeholder="点击获取昵称" bindblur="getName" />
        <view class="auth-status">待授权</view>
      </view>
    </view>

    <!-- 手机号授权 -->
    <view class="auth-item">
      <view class="auth-title">手机号授权</view>
      <view class="auth-content" wx:if="{{hasPhoneNumber}}">
        <view class="phone-info">{{phoneNumber}}</view>
        <view class="auth-status success">已完成授权</view>
      </view>
      <view class="auth-content" wx:else>
        <view class="auth-desc">用于身份识别</view>
        <button class="auth-btn" open-type="getPhoneNumber" bindgetphonenumber="getPhoneNumber">立即授权</button>
        <view class="auth-status">待授权</view>
      </view>
    </view>
  </view>

  <view class="footer">
    <button class="complete-btn" bindtap="completeLogin">完成授权并进入</button>
    <view class="privacy-policy">点击上方按钮，即表示您已阅读并同意<text class="link">《用户协议》</text>和<text class="link">《隐私政策》</text></view>
  </view>
</view>