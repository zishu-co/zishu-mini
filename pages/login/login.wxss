/* pages/login/login.wxss */
page {
  background: linear-gradient(180deg, #f5f3ff 0%, #ede9fe 50%, #e9d5ff 100%);
  min-height: 100vh;
}

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx 40rpx;
  box-sizing: border-box;
  min-height: 100vh;
  position: relative;
}

/* 装饰背景圆 */
.decor-circle {
  position: absolute;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(167, 139, 250, 0.3), rgba(139, 92, 246, 0.1));
}

.decor-circle-1 {
  width: 300rpx;
  height: 300rpx;
  top: -100rpx;
  right: -80rpx;
  animation: float 6s ease-in-out infinite;
}

.decor-circle-2 {
  width: 200rpx;
  height: 200rpx;
  top: 200rpx;
  left: -60rpx;
  animation: float 8s ease-in-out infinite reverse;
}

.decor-circle-3 {
  width: 150rpx;
  height: 150rpx;
  bottom: 300rpx;
  right: -40rpx;
  animation: float 5s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0) scale(1); }
  50% { transform: translateY(-20rpx) scale(1.05); }
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 40rpx 0 60rpx;
  width: 100%;
  animation: fadeInDown 0.8s ease-out;
}

@keyframes fadeInDown {
  from {
    opacity: 0;
    transform: translateY(-30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}



.welcome-text {
  text-align: center;
  margin-top: 20rpx;
}

.welcome-title {
  font-size: 52rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #7c3aed, #a855f7, #c084fc);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 16rpx;
  letter-spacing: 4rpx;
}

.welcome-subtitle {
  font-size: 28rpx;
  color: #8b5cf6;
  opacity: 0.8;
}

.auth-section {
  width: 100%;
  margin-bottom: 60rpx;
  animation: fadeInUp 0.8s ease-out 0.2s both;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.auth-item {
  background-color: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(139, 92, 246, 0.12);
  position: relative;
  overflow: hidden;
  backdrop-filter: blur(10px);
  border: 1rpx solid rgba(167, 139, 250, 0.2);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.auth-item:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 16rpx rgba(139, 92, 246, 0.1);
}

/* 左侧渐变条 */
.auth-item::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  width: 8rpx;
  height: 100%;
  background: linear-gradient(to bottom, #a855f7, #7c3aed);
  border-radius: 4rpx 0 0 4rpx;
}

.auth-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  color: #4c1d95;
  display: flex;
  align-items: center;
}

.auth-title::before {
  content: "✨";
  display: inline-block;
  margin-right: 12rpx;
  font-size: 28rpx;
}

.auth-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-height: 80rpx;
}

.auth-desc {
  font-size: 28rpx;
  color: #7c3aed;
  opacity: 0.7;
  flex: 1;
}

.auth-btn {
  background: linear-gradient(135deg, #a855f7 0%, #7c3aed 100%);
  color: #fff;
  font-size: 28rpx;
  padding: 0 36rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  margin: 0;
  font-weight: 500;
  box-shadow: 0 6rpx 20rpx rgba(139, 92, 246, 0.35);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.auth-btn:active {
  transform: scale(0.95);
  box-shadow: 0 3rpx 10rpx rgba(139, 92, 246, 0.25);
}

/* 获取头像按钮特殊样式 */
.pop_avatar {
  background: linear-gradient(135deg, #a855f7 0%, #7c3aed 100%);
  color: #fff;
  font-size: 28rpx;
  padding: 0 36rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  font-weight: 500;
  box-shadow: 0 6rpx 20rpx rgba(139, 92, 246, 0.35);
}

.pop_avatar::after {
  border: none;
}

/* 昵称输入框 */
.ipu {
  flex: 1;
  font-size: 28rpx;
  color: #4c1d95;
  background: linear-gradient(135deg, rgba(167, 139, 250, 0.1), rgba(139, 92, 246, 0.05));
  border: 2rpx solid rgba(167, 139, 250, 0.3);
  border-radius: 36rpx;
  padding: 0 30rpx;
  height: 72rpx;
  line-height: 72rpx;
}

.ipu::placeholder {
  color: #a78bfa;
}

.auth-status {
  font-size: 26rpx;
  color: #a78bfa;
  margin-left: 20rpx;
  display: flex;
  align-items: center;
  white-space: nowrap;
}

.auth-status.success {
  color: #10b981;
  font-weight: 500;
}

.auth-status.success::before {
  content: "✓";
  display: inline-block;
  margin-right: 8rpx;
  font-weight: bold;
  font-size: 28rpx;
}

.user-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  border: 3rpx solid rgba(167, 139, 250, 0.3);
  box-shadow: 0 4rpx 12rpx rgba(139, 92, 246, 0.2);
}

.nickname,
.phone-info {
  font-size: 30rpx;
  color: #4c1d95;
  font-weight: 500;
}

.footer {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  animation: fadeInUp 0.8s ease-out 0.4s both;
}

.complete-btn {
  width: 90%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #a855f7 0%, #7c3aed 50%, #6d28d9 100%);
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 48rpx;
  margin-bottom: 36rpx;
  box-shadow: 0 12rpx 32rpx rgba(139, 92, 246, 0.4);
  letter-spacing: 4rpx;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  position: relative;
  overflow: hidden;
}

.complete-btn::before {
  content: "";
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.5s ease;
}

.complete-btn:active::before {
  left: 100%;
}

.complete-btn:active {
  transform: scale(0.98);
  box-shadow: 0 6rpx 16rpx rgba(139, 92, 246, 0.3);
}

.privacy-policy {
  font-size: 24rpx;
  color: #8b5cf6;
  line-height: 1.6;
  text-align: center;
  opacity: 0.8;
}

.link {
  color: #7c3aed;
  text-decoration: none;
  font-weight: 500;
  border-bottom: 1rpx solid rgba(124, 58, 237, 0.3);
}
