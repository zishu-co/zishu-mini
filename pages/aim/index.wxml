<view class="aim-page">
  <!-- 顶部区域：今日推荐 -->
  <view class="section-recommendation">
    <top3-recommendation 
      recommendations="{{recommendations}}"
      loading="{{recommendationLoading}}"
      refreshing="{{recommendationRefreshing}}"
      lastUpdated="{{lastUpdated}}"
      bind:refresh="onRefreshRecommendation"
      bind:itemtap="onRecommendationItemTap"
      bind:actiontap="onRecommendationActionTap"
    />
  </view>

  <!-- 主内容区域：当前目标 -->
  <view class="section-goal">
    <goal-card
      goal="{{currentGoal}}"
      loading="{{goalLoading}}"
      bind:edit="onEditGoal"
      bind:create="onCreateGoal"
      bind:updateProgress="onUpdateProgress"
    />
  </view>
</view>

<t-toast id="t-toast" />
