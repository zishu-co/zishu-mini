<view class="user-card">
  <view class="user-card__bg"></view>
  <view class="user-card__content">
    <view class="user-card__avatar" bindtap="gotoUserEditPage">
      <image
        class="avatar-img"
        src="{{userInfo.avatarUrl || '/img/logo.png'}}"
        mode="aspectFill"
      />
    </view>
    <view class="user-card__info" bindtap="gotoUserEditPage">
      <view class="nickname">{{userInfo.nickName || '未登录'}}</view>
      <view class="phone" wx:if="{{userInfo.phoneNumber}}">{{userInfo.phoneNumber}}</view>
    </view>
    <view class="user-card__arrow" bindtap="gotoUserEditPage">
      <text class="arrow-icon">></text>
    </view>
  </view>
</view>

<view class="content-wrapper">
  <!-- 订单入口 -->
  <view class="order-section">
    <view class="section-header">
      <text class="section-title">我的订单</text>
      <text class="section-more" bindtap="jumpAllOrder">全部订单 ></text>
    </view>
    <view class="order-icons">
      <view class="order-item" bindtap="jumpNav" data-status="5">
        <text class="order-icon">💳</text>
        <text class="order-label">待付款</text>
      </view>
      <view class="order-item" bindtap="jumpNav" data-status="10">
        <text class="order-icon">📦</text>
        <text class="order-label">待发货</text>
      </view>
      <view class="order-item" bindtap="jumpNav" data-status="40">
        <text class="order-icon">🚚</text>
        <text class="order-label">待收货</text>
      </view>
      <view class="order-item" bindtap="jumpNav" data-status="60">
        <text class="order-icon">⭐</text>
        <text class="order-label">待评价</text>
      </view>
      <view class="order-item" bindtap="jumpNav" data-status="0">
        <text class="order-icon">🔧</text>
        <text class="order-label">退款/售后</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="onClickCell" data-type="address">
      <text class="menu-icon">📍</text>
      <text class="menu-text">收货地址</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="onClickCell" data-type="coupon">
      <text class="menu-icon">🎫</text>
      <text class="menu-text">优惠券</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="onClickCell" data-type="point">
      <text class="menu-icon">💰</text>
      <text class="menu-text">积分</text>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="onClickCell" data-type="help-center">
      <text class="menu-icon">❓</text>
      <text class="menu-text">帮助中心</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="onClickCell" data-type="service">
      <text class="menu-icon">📞</text>
      <text class="menu-text">客服热线</text>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <!-- 退出登录按钮 -->
  <view class="logout-wrapper" wx:if="{{currAuthStep === 2}}">
    <button class="logout-btn" bindtap="logOut">退出登录</button>
  </view>
</view>


<!-- 客服弹窗 -->
<t-popup visible="{{showMakePhone}}" placement="bottom" bind:visible-change="closeMakePhone">
  <view class="popup-content">
    <view class="popup-title border-bottom-1px" wx:if="{{customerServiceInfo.serviceTimeDuration}}">
      服务时间: {{customerServiceInfo.serviceTimeDuration}}
    </view>
    <view class="popup-phone" bind:tap="call">电话客服</view>
    <view class="popup-close" bind:tap="closeMakePhone">取消</view>
  </view>
</t-popup>
<t-toast id="t-toast" />
